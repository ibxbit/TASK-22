# Copy this file to .env and replace every placeholder with real values.
# The backend refuses to start with NODE_ENV=production if placeholder values are detected.
#
# Generate a 64-char hex encryption key (32 random bytes):
#   openssl rand -hex 32
#
# Generate an HMAC secret (at least 32 chars):
#   openssl rand -hex 32

NODE_ENV=production

# AES-256-GCM encryption key for sensitive fields at rest.
# Format: 64 hexadecimal characters (= 32 bytes).
ENCRYPTION_KEY_CURRENT=v1
ENCRYPTION_KEY_v1=REPLACE_WITH_64_CHAR_HEX_STRING_HERE_00000000000000000000000000000

# Key rotation: add new version before retiring the old one.
# ENCRYPTION_KEY_v2=REPLACE_WITH_ANOTHER_64_CHAR_HEX_STRING_000000000000000000000000

# HMAC-SHA256 secret for request signing (anti-replay, server-to-server).
HMAC_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS_HERE

# JWT signing secret for user session tokens.
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS_HERE_2
